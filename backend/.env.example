# Database — SQLite (default, no setup needed) or PostgreSQL
# For local dev without PostgreSQL:
DATABASE_URL=sqlite:///./recyx.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/recyx_db

# JWT settings
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256 # The algorithm used to sign the JWT tokens, which should be a secure choice like HS256 or RS256 to ensure token integrity and security.
ACCESS_TOKEN_EXPIRE_HOURS=12 # Access tokens will expire after 12 hours, requiring users to re-authenticate for continued access, which enhances security by limiting the window of opportunity for token misuse.

# Redis / Celery (optional for dev)
REDIS_URL=redis://localhost:6379/0

# App settings
APP_ENV=development
FRONTEND_URL=http://localhost:3000
