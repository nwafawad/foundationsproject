# Database — SQLite (default, no setup needed) or PostgreSQL
# For local dev without PostgreSQL:
DATABASE_URL=sqlite:///./recyx.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/recyx_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=12

# Redis / Celery (optional for dev)
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
